# Copy this file to .env and fill in real values. Do NOT commit .env to version control.

# -- Database ------------------------------------------------------------------
DB_HOST=db
DB_USER=app_user
DB_PASSWORD=your_strong_db_password_here
DB_NAME=aether_trading
DB_PORT=3306
# Used when running PHP CLI directly on the host (not inside Docker)
DB_HOST_LOCAL=127.0.0.1
DB_PORT_LOCAL=3307

# MySQL root password (used by docker-compose for the MySQL container itself)
MYSQL_ROOT_PASSWORD=your_strong_root_password_here

# -- SMTP / Email ---------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_USER=your-email@example.com
SMTP_PASS=your_gmail_app_password_here
SMTP_PORT=587
SMTP_SECURE=tls
SMTP_FROM=your-email@example.com

# Max send attempts for alerts (default 3)
MAX_SEND_ATTEMPTS=3

# -- Blockchain / Ganache -------------------------------------------------------
# The private key of the exchange owner wallet in Ganache (Account #0)
# NEVER commit a real mainnet private key here.
EXCHANGE_OWNER_PRIVATE_KEY=0xYOUR_GANACHE_ACCOUNT_PRIVATE_KEY_HERE

# Ganache RPC URL (use host.docker.internal when running PHP inside Docker)
GANACHE_RPC_URL=http://host.docker.internal:7545

# Smart contract address printed after running: truffle migrate
CONTRACT_ADDRESS=0xYOUR_DEPLOYED_CONTRACT_ADDRESS_HERE

# Exchange treasury wallet address (Ganache Account #2)
EXCHANGE_WALLET=0xYOUR_GANACHE_EXCHANGE_WALLET_ADDRESS_HERE

# -- Cache TTL Settings (optional) ---------------------------------------------
# Max news cache TTL in seconds (default 1800 = 30 minutes)
NEWS_CACHE_TTL=1800

# Fear & Greed index cache TTL in seconds (default 900 = 15 minutes)
FGI_CACHE_TTL=900

# -- Application ---------------------------------------------------------------
# Set to development to expose OTP codes in the session for local testing
# APP_ENV=development
